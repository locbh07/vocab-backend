DATABASE_URL=postgresql://postgres:password@localhost:5432/vocab
# For Supabase, include SSL:
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
# Server-side only. Never expose this key through a VITE_* variable.
GOOGLE_TRANSLATE_API_KEY=
PORT=4000
# Comma-separated allowed origins, e.g.
# CORS_ORIGIN=https://jp-vocab-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional override for exam explanation endpoint
OPENAI_EXAM_MODEL=gpt-4o-mini

# API anti-scraping shield. Defaults are conservative and can be tightened in production.
API_SHIELD_ENABLED=true
API_SHIELD_WINDOW_MS=60000
API_SHIELD_DISTINCT_WINDOW_MS=300000
API_SHIELD_BLOCK_MS=600000
API_SHIELD_MAX_DISTINCT_USERS_PER_IP=6
API_SHIELD_MAX_REQUESTS_PER_IP=
API_SHIELD_MAX_REQUESTS_PER_USER=
API_SHIELD_SUSPICIOUS_SCORE_WINDOW_MS=300000
API_SHIELD_SUSPICIOUS_SCORE_THRESHOLD=14
API_SHIELD_MAX_DISTINCT_TARGETS_PER_IP=80
API_SHIELD_RAPID_REQUEST_INTERVAL_MS=250
API_SHIELD_RAPID_REQUEST_BURST=18
API_SHIELD_MAX_SEQUENTIAL_NUMERIC_TARGETS=12
