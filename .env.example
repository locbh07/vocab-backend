DATABASE_URL=postgresql://postgres:password@localhost:5432/vocab
# For Supabase, include SSL:
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
PORT=4000
# Comma-separated allowed origins, e.g.
# CORS_ORIGIN=https://jp-vocab-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional override for exam explanation endpoint
OPENAI_EXAM_MODEL=gpt-4o-mini
