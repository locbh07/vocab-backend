DATABASE_URL=postgresql://postgres:password@localhost:5432/vocab
# For Supabase, include SSL:
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
# Server-side only. Never expose this key through a VITE_* variable.
GOOGLE_TRANSLATE_API_KEY=
PORT=4000
# Comma-separated allowed origins, e.g.
# CORS_ORIGIN=https://jp-vocab-frontend.vercel.app,http://localhost:5173
CORS_ORIGIN=
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional override for exam explanation endpoint
OPENAI_EXAM_MODEL=gpt-4o-mini
GEMINI_API_KEY=
# Optional, defaults to gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
# Optional override for exam explanation feature (default provider as of 2026-07-10; see docs/ai-content-review-design.md)
GEMINI_EXAM_MODEL=gemini-2.5-flash
# Optional, defaults to gemini-2.5-flash-image (used by /admin/kids-mascot image generation)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Stripe premium billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=
STRIPE_PREMIUM_LIFETIME_PRICE_ID=
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/account?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/account?checkout=cancel

# Manual premium payments. MSB uses dynamic VietQR with amount + transfer content.
# PayPay uses PayPay ID; the app generates a QR that opens PayPay, then the user sends manually.
MANUAL_PAYMENT_MSB_BANK_ID=MSB
MANUAL_PAYMENT_MSB_ACCOUNT_NO=
MANUAL_PAYMENT_MSB_ACCOUNT_NAME=
MANUAL_PAYMENT_MSB_MONTHLY_AMOUNT=99000
MANUAL_PAYMENT_MSB_YEARLY_AMOUNT=365000
MANUAL_PAYMENT_MSB_LIFETIME_AMOUNT=1699000
MANUAL_PAYMENT_MSB_QR_TEMPLATE=compact2

MANUAL_PAYMENT_PAYPAY_ACCOUNT_ID=
MANUAL_PAYMENT_PAYPAY_ACCOUNT_NAME=
MANUAL_PAYMENT_PAYPAY_MONTHLY_AMOUNT=990
MANUAL_PAYMENT_PAYPAY_YEARLY_AMOUNT=3650
MANUAL_PAYMENT_PAYPAY_LIFETIME_AMOUNT=16999
PREMIUM_MONTHLY_DAYS=30
PREMIUM_YEARLY_DAYS=365
PREMIUM_TRIAL_DAYS=30

# Internal Telegram notifications. Keep the real bot token server-side only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Exam access. Free users can access this many exams per JLPT level.
# Premium/Admin accounts can access all exams.
FREE_EXAM_LIMIT_PER_LEVEL=5

# Listening/shadowing access. Free users can access this many videos per JLPT level.
# Premium/Admin accounts can access all videos.
LISTENING_FREE_VIDEO_LIMIT_PER_LEVEL=10

# API anti-scraping shield. Defaults are conservative and can be tightened in production.
API_SHIELD_ENABLED=true
API_SHIELD_WINDOW_MS=60000
API_SHIELD_DISTINCT_WINDOW_MS=300000
API_SHIELD_BLOCK_MS=600000
API_SHIELD_MAX_DISTINCT_USERS_PER_IP=6
API_SHIELD_MAX_REQUESTS_PER_IP=
API_SHIELD_MAX_REQUESTS_PER_USER=
API_SHIELD_SUSPICIOUS_SCORE_WINDOW_MS=300000
API_SHIELD_SUSPICIOUS_SCORE_THRESHOLD=14
API_SHIELD_MAX_DISTINCT_TARGETS_PER_IP=80
API_SHIELD_RAPID_REQUEST_INTERVAL_MS=250
API_SHIELD_RAPID_REQUEST_BURST=18
API_SHIELD_MAX_SEQUENTIAL_NUMERIC_TARGETS=12
