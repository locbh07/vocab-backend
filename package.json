{
  "name": "vocab-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env:local": "node scripts/use-env.cjs local",
    "env:staging": "node scripts/use-env.cjs staging",
    "env:production": "node scripts/use-env.cjs production",
    "dev": "kill-port 4000 && ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:local": "npm run env:local && npm run dev",
    "dev:staging": "npm run env:staging && npm run dev",
    "dev:production": "npm run env:production && npm run dev",
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "exam:meta:backfill": "npm run build && node scripts/backfill-exam-metadata.cjs",
    "grammar:reclassify": "node scripts/reclassify-grammar.cjs",
    "grammar:seed:baseline": "node scripts/seed-grammar-missing-baseline.cjs",
    "grammar:map:units": "node scripts/map-grammar-source-units.cjs",
    "grammar:reference:build": "node scripts/build-grammar-reference-from-bunpro.cjs",
    "grammar:reference:sync": "node scripts/sync-grammar-with-reference.cjs",
    "grammar:dedupe": "node scripts/consolidate-grammar-duplicates.cjs",
    "grammar:fill:meaning": "node scripts/fill-grammar-meaning-from-existing.cjs",
    "grammar:fill:meaning:reference": "node scripts/fill-grammar-meaning-from-reference.cjs",
    "grammar:translate:meaning:en2vi": "node scripts/translate-grammar-meanings-en-to-vi.cjs",
    "grammar:fill:content:bulk": "node scripts/bulk-fill-grammar-content.cjs",
    "grammar:enrich:bunpro": "node scripts/enrich-grammar-from-bunpro-pages.cjs",
    "grammar:replace:real-examples": "node scripts/replace-placeholder-examples-with-real.cjs",
    "grammar:enforce:core-reference": "node scripts/enforce-core-reference-only.cjs",
    "kanji:compounds:build": "node scripts/build-kanji-compounds.cjs",
    "kanji:compounds:build:jmdict-refresh": "node scripts/build-kanji-compounds.cjs --refresh-jmdict",
    "kanji:compounds:build:mazii": "node scripts/build-kanji-compounds.cjs --use-mazii",
    "kanji:compounds:build:mazii:vocab-only": "node scripts/build-kanji-compounds.cjs --use-mazii --skip-jmdict",
    "kanji:compounds:build:mazii:prewarm": "node scripts/build-kanji-compounds.cjs --use-mazii --prewarm-cache",
    "kanji:compounds:backfill:mazii-vi": "node scripts/build-kanji-compounds.cjs --use-mazii --skip-jmdict --no-reset --mazii-backfill-jmdict-vi",
    "kanji:compounds:build:vocab-only": "node scripts/build-kanji-compounds.cjs --skip-jmdict",
    "kanji:compounds:prewarm": "node scripts/build-kanji-compounds.cjs --prewarm-only",
    "listening:import:json": "node scripts/import-listening-from-json.cjs",
    "vocab:import:books": "node scripts/import-book-vocabulary-from-export.cjs",
    "db:sync:staging-to-local": "powershell -ExecutionPolicy Bypass -File scripts/sync-db-from-server.ps1 -From staging",
    "db:sync:production-to-local": "powershell -ExecutionPolicy Bypass -File scripts/sync-db-from-server.ps1 -From production",
    "prisma": "prisma",
    "prisma:migrate:dev:local": "npm run env:local && npm run prisma -- migrate dev",
    "prisma:migrate:deploy:staging": "npm run env:staging && npm run prisma -- migrate deploy",
    "prisma:migrate:deploy:production": "npm run env:production && npm run prisma -- migrate deploy",
    "prisma:studio:local": "npm run env:local && npm run prisma -- studio",
    "prisma:studio:staging": "npm run env:staging && npm run prisma -- studio"
  },
  "dependencies": {
    "@prisma/client": "^4.16.2",
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "kuromoji": "^0.1.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "kill-port": "^2.0.1",
    "prisma": "^4.16.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
